APP_NAME=GertLex
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://app.gertlex.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── BANCO DE DADOS ───────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gertlex
DB_USERNAME=gertlex
DB_PASSWORD=

# ─── CACHE / SESSÃO / FILAS ───────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── FILESYSTEM (DigitalOcean Spaces / S3) ────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=nyc3
AWS_BUCKET=gertlex-docs
AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── MAIL (Resend recomendado) ────────────────────────────────
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@gertlex.com.br"
MAIL_FROM_NAME="GertLex"
RESEND_KEY=

# ─── CLAUDE / IA ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20251001

# ─── ASAAS (Pagamentos) ───────────────────────────────────────
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=production

# ─── DATAJUD CNJ ──────────────────────────────────────────────
DATAJUD_API_KEY=
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br

# ─── VITE ─────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
